{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.2.5|^8.0",
        "2checkout/2checkout-php": "^0.4.0",
        "authorizenet/authorizenet": "2.0.2",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "cartalyst/stripe-laravel": "12.0.*",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^6.3.1|^7.0.1",
        "instamojo/instamojo-php": "^0.4.0",
        "intervention/image": "^2.5",
        "laravel/framework": "^7.29",
        "laravel/socialite": "^4.4",
        "laravel/tinker": "^2.5",
        "mercadopago/dx-php": "2.2.1",
        "mollie/laravel-mollie": "^2.0",
        "paypal/rest-api-sdk-php": "*",
        "razorpay/razorpay": "2.*",
        "tymon/jwt-auth": "^1.0",
        "yajra/laravel-datatables-oracle": "^9.10",
        "zanysoft/laravel-zip": "^1.0"
    },
    "require-dev": {
        "facade/ignition": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^4.3",
        "phpunit/phpunit": "^8.5.8|^9.3.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files" : [
            "app/Helpers/PriceHelper.php",
            "app/Helpers/CaptchaHelper.php"
        ],
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Markury\\": "vendor/markury/src/Adapter"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
